-- ===== BUAT SEMUA KARTU DULUAN, HIDDEN =====
local cardRefs = {}

local function createCard(d)
    local card = Instance.new("Frame")
    card.Name = d.key
    card.BackgroundColor3 = Color3.fromRGB(26, 24, 0)
    card.BorderSizePixel = 0
    card.Visible = false -- sembunyiin dulu
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 215, 0)
    stroke.Thickness = 1
    stroke.Parent = card

    local topBar = Instance.new("Frame")
    topBar.Size = UDim2.new(1, 0, 0, 2)
    topBar.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    topBar.BorderSizePixel = 0
    Instance.new("UICorner", topBar).CornerRadius = UDim.new(0, 10)
    topBar.Parent = card

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 32)
    iconLabel.Position = UDim2.new(0, 0, 0, 10)
    iconLabel.Text = d.icon
    iconLabel.BackgroundTransparency = 1
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.TextSize = 24
    iconLabel.Parent = card

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -12, 0, 20)
    nameLabel.Position = UDim2.new(0, 6, 0, 44)
    nameLabel.Text = d.name:upper()
    nameLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 13
    nameLabel.Parent = card

    local tierLabel = Instance.new("TextLabel")
    tierLabel.Size = UDim2.new(1, -12, 0, 16)
    tierLabel.Position = UDim2.new(0, 6, 0, 62)
    tierLabel.Text = "MYTHICAL"
    tierLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    tierLabel.TextTransparency = 0.5
    tierLabel.BackgroundTransparency = 1
    tierLabel.Font = Enum.Font.GothamBold
    tierLabel.TextSize = 9
    tierLabel.Parent = card

    card.Parent = listFrame
    cardRefs[d.key] = card
end

-- Bikin semua kartu sekarang, tapi hidden
for _, d in ipairs(mythicalData) do
    createCard(d)
end

-- ===== UPDATE UI =====
local function updateUI(data)
    -- Reset semua hidden dulu
    for _, card in pairs(cardRefs) do
        card.Visible = false
    end

    local foundCount = 0

    for _, itemData in pairs(data) do
        local name = itemData.Name or tostring(itemData)
        if mythicalSet[name] and cardRefs[name] then
            cardRefs[name].Visible = true
            foundCount += 1
        end
    end

    countBadge.Text = "FOUND: " .. foundCount .. " / 11"
end

-- ===== HOOK =====
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    if getnamecallmethod() == "InvokeServer"
        and self.Name == "CommF_"
        and args[1] == "getInventory" then
        local data = oldNamecall(self, ...)
        updateUI(data)
        return data
    end
    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

print("[MythicalViewer] UI aktif — buka inventory lu sekarang!")
